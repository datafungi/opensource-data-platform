project_name = "datafungi-lab"
location     = "southeastasia"

admin_username      = "azureuser"
ssh_public_key_path = "~/.ssh/id_rsa.pub"

allowed_ssh_cidrs = [
  "203.0.113.10/32"
]

create_jumpbox_public_ip = false

vm_size = "Standard_D4as_v5"

os_disk_size_gb   = 64
data_disk_size_gb = 256

install_dokploy_on_control_vm = true

enable_daily_shutdown      = true
daily_shutdown_time        = "2300"
daily_shutdown_timezone    = "SE Asia Standard Time"
enable_inactivity_shutdown = true
inactivity_cpu_threshold   = 5

create_log_analytics_workspace = true
log_analytics_retention_days   = 30

enable_budget_alert   = false
monthly_budget_amount = 150
budget_alert_emails   = []

tags = {
  purpose = "data-infra-practice"
}
