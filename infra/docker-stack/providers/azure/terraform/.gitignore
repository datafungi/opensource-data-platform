# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local variable overrides — contain secrets
terraform.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Plan output files
*.tfplan
*.tfplan.json

# Crash logs
crash.log
crash.*.log

# Override files (local dev only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
