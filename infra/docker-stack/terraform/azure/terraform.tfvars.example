# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored — never commit it.

# ── Azure region ──────────────────────────────────────────────────────────────
location = "southeastasia"

# ── Environment / naming ──────────────────────────────────────────────────────
# Allowed: dev | staging | prod
# Two resource groups are created:
#   <project>-<environment>-network-rg   — VNet, subnets, NSGs, Tailscale VM
#   <project>-<environment>-platform-rg  — cluster VMs, storage, Key Vault
environment = "dev"
project     = "data-platform"

# ── VM sizing ─────────────────────────────────────────────────────────────────
# Standard_D4s_v5 = 4 vCPU, 16 GiB RAM (~$140/month PAYG per VM in East US)
# Downsize to Standard_D2s_v5 (2 vCPU, 8 GiB) for non-production to save ~50%.
# The Tailscale VM is always Standard_B1s (~$8/month) regardless of this value.
vm_size        = "Standard_D4s_v5"
admin_username = "azureuser"

# ── Bastion / SSH CIDR ────────────────────────────────────────────────────────
# Option A (recommended for production): Azure Bastion — adds ~$140/month
# enable_bastion   = true
# allowed_ssh_cidr = ""

# Option B (dev / cost-conscious): NSG-restricted direct SSH
# Not needed for cluster nodes once Tailscale is enabled — SSH via tailnet.
enable_bastion   = false
allowed_ssh_cidr = "203.0.113.0/24" # Replace with your public IP or CIDR

# ── Tailscale subnet router / VPN exit node ───────────────────────────────────
# When enabled, provisions a Standard_B1s VM (~$8/month) in tailscale-subnet
# (10.54.0.0/24) that:
#   - Acts as a subnet router: advertises 10.54.0.0/16 to your tailnet so any
#     tailnet device can reach cluster nodes without Tailscale installed on them.
#   - Acts as a VPN exit node: routes all internet traffic through this VM,
#     giving you a self-hosted VPN exit point in your Azure region.
#
# Terraform generates a reusable auth key automatically via the Tailscale API —
# no manual key creation needed. The key is stored in Key Vault and retrieved
# by cloud-init at first boot.
#
# One-time setup:
#   1. Go to https://login.tailscale.com/admin/settings/oauth
#   2. Create an OAuth client with the "auth_keys" write scope
#   3. Copy the client ID and secret below
#
# After first apply, approve the advertised routes and exit node at:
#   https://login.tailscale.com/admin/machines
enable_tailscale              = false
tailscale_oauth_client_id     = ""           # tskey-client-... (client ID)
tailscale_oauth_client_secret = ""           # tskey-client-... (client secret)
# tailscale_tags must match a tagOwners entry in your tailnet ACL policy.
# Add {"tagOwners": {"tag:server": []}} at https://login.tailscale.com/admin/acls
tailscale_tags                = ["tag:server"]

# ── Storage ───────────────────────────────────────────────────────────────────
backup_retention_days = 30
data_disk_size_gb     = 256 # GiB; Premium SSD P15 tier

# ── Auto-shutdown (cluster nodes only) ────────────────────────────────────────
# Shuts down the 3 cluster VMs daily at the given time to save compute costs.
# The Tailscale VM is never affected — it keeps the VNet reachable via tailnet.
# auto_shutdown_time uses HHMM format; auto_shutdown_timezone must be a Windows
# timezone ID (Azure requirement). Run `tzutil /l` on Windows or see:
# https://learn.microsoft.com/en-us/windows-hardware/manufacture/desktop/default-time-zones
auto_shutdown_enabled  = true
auto_shutdown_time     = "2300"
auto_shutdown_timezone = "SE Asia Standard Time" # Asia/Ho_Chi_Minh

# ── Tags ──────────────────────────────────────────────────────────────────────
tags = {
  owner       = "your-name"
  repo        = "opensource-data-platform"
  cost_center = "personal"
}
