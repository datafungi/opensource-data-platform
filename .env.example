# Airflow environment variables
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=replace-with-a-generated-fernet-key

# Source PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=replace-with-your-postgres-password

# Trino server
TRINO_SHARED_SECRET=replace-with-a-long-random-string

# LDAP
# Keep LDAP DN and domain aligned with infra/dev/configs/ldap and
# infra/dev/configs/trino unless you update those config files too.
LDAP_ORGANISATION=OSS Data Platform
LDAP_DOMAIN=oss-data-platform.local
LDAP_BASE_DN=dc=oss-data-platform,dc=local
LDAP_ADMIN_PASSWORD=admin

# Ranger
RANGER_DB_SUPERUSER_PASSWORD=rangerR0cks!
RANGER_DB_USER=rangeradmin
RANGER_DB_PASSWORD=rangerR0cks!
RANGER_POLICY_MGR_URL=http://ranger-admin:6080
RANGER_USERSYNC_INTERVAL_MINUTES=5

# Trino catalogs
SEAWEEDFS_ACCESS_KEY=seaweedadmin
SEAWEEDFS_SECRET_KEY=seaweedadmin
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Polaris catalog principal
# Format is client_id:client_secret
POLARIS_CLIENT_CREDENTIAL=root:s3cr3t
POLARIS_OAUTH2_SERVER_URI=http://polaris:8181/api/catalog/v1/oauth/tokens
POLARIS_OAUTH2_SCOPE=PRINCIPAL_ROLE:ALL
POLARIS_BOOTSTRAP_CLIENT_ID=root
POLARIS_BOOTSTRAP_CLIENT_SECRET=s3cr3t
POLARIS_DB_USER=postgres
POLARIS_DB_PASSWORD=postgres
POLARIS_DB_NAME=POLARIS
